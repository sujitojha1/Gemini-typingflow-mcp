# Google GenAI API key — get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model overrides (optional — defaults shown)
STRUCTURE_MODEL=gemini-2.5-flash
IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# Track 2 agent tools use Ollama — set model and server URL
OLLAMA_URL=http://localhost:11434

# Pick any locally pulled model; good options ranked by quality vs speed:
#   gemma3:12b    — best quality, ~8 GB
#   gemma4:e4b    — Gemma 4 efficient 4B, ~9.6 GB
#   gemma3:4b     — solid default, ~3.3 GB
#   gemma4:e2b    — Gemma 4 efficient 2B, ~7.2 GB  (faster)
#   granite4.1:3b — IBM Granite 4.1, ~2.1 GB       (fastest)
OLLAMA_TOOL_MODEL=gemma3:4b

# Concurrency and chunking (optional)
CONCURRENCY_LIMIT=5
MULTIPASS_WORD_THRESHOLD=3000
SECTION_MAX_WORDS=2000
