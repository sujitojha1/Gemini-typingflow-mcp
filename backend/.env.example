# Google GenAI API key — get yours at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Model overrides (optional — defaults shown)
STRUCTURE_MODEL=gemini-2.5-flash
TOOL_MODEL=gemini-2.5-flash-lite
IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# Concurrency and chunking (optional)
CONCURRENCY_LIMIT=5
MULTIPASS_WORD_THRESHOLD=3000
SECTION_MAX_WORDS=2000
